{
  "manifest_version": 3,
  "default_locale": "en",
  "name": "__MSG_appName__",
  "version": "0.1.5",
  "description": "__MSG_appDesc__",
  "minimum_chrome_version": "116",
  "key": "",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "tabs",
    "tabGroups",
    "bookmarks",
    "history",
    "storage",
    "alarms",
    "sidePanel",
    "nativeMessaging",
    "notifications"
  ],
  "optional_host_permissions": ["<all_urls>", "https://registry.npmjs.org/*"],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "Browser Organizer",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "omnibox": { "keyword": "org" },
  "commands": {
    "run-scan": { "suggested_key": { "default": "Ctrl+Shift+O" }, "description": "Analyze tabs & bookmarks" },
    "open-panel": { "description": "Open Browser Organizer" }
  }
}
