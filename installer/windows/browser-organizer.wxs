<?xml version="1.0" encoding="utf-8"?>
<!--
  Browser Organizer native host — per-machine MSI (for administrators).

  TOOLCHAIN: WiX Toolset v4/v5 (installed as a dotnet global tool). Build with:
    wix build installer\windows\browser-organizer.wxs -d Version=0.1.1 -arch x64 -o dist\BrowserOrganizer.msi
  from the repo root. Expects the SEA binary at dist\host\browser-organizer-host.exe
  (from `npm run build:sea`). Not built in the offline sandbox — only on a
  windows-latest runner (see .github/workflows/release-host.yml) or by a maintainer.

  Unlike the per-user Inno EXE (HKCU, %LOCALAPPDATA%), this installs per-machine:
  the binary + manifest go under Program Files and the native-messaging host is
  registered in HKLM, so every user on the machine can reach it. It declares the
  files and registry as MSI components (clean install/upgrade/rollback) rather
  than shelling out to the binary, so no custom actions run.

  ADMIN / DEPLOYMENT FLAGS (msiexec):
    Silent install:        msiexec /i BrowserOrganizer.msi /qn /norestart
    Verbose log:           msiexec /i BrowserOrganizer.msi /qn /l*v install.log
    Custom location:       msiexec /i BrowserOrganizer.msi INSTALLFOLDER="C:\Apps\BrowserOrganizer" /qn
    Register Chrome only:  msiexec /i BrowserOrganizer.msi EDGE=0 /qn
    Register Edge only:    msiexec /i BrowserOrganizer.msi CHROME=0 /qn
    Also register Chromium: msiexec /i BrowserOrganizer.msi CHROMIUM=1 /qn
    Uninstall:             msiexec /x BrowserOrganizer.msi /qn
  Requires elevation (per-machine); GPO/Intune/SCCM run it as SYSTEM. MajorUpgrade
  lets a newer MSI replace an older install in place.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="Browser Organizer Host"
    Manufacturer="Lusk Technologies"
    Version="$(Version)"
    UpgradeCode="7B2A9F14-3C6E-4D5A-9E1B-8F0C2D3A4B5C"
    Scope="perMachine"
    Compressed="yes">

    <MajorUpgrade DowngradeErrorMessage="A newer version of Browser Organizer Host is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <!-- Admin-overridable public properties (set on the msiexec command line). -->
    <Property Id="CHROME" Value="1" />
    <Property Id="EDGE" Value="1" />
    <Property Id="CHROMIUM" Value="0" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="Browser Organizer">
        <Component Id="HostExe" Bitness="always64">
          <File Id="HostExe" Source="dist\host\browser-organizer-host.exe" KeyPath="yes" />
        </Component>
        <Component Id="HostManifest" Bitness="always64">
          <File Id="HostManifest" Name="com.browser_organizer.host.json"
                Source="installer\windows\com.browser_organizer.host.json" KeyPath="yes" />
        </Component>
        <Component Id="RegChrome" Bitness="always64" Condition="CHROME = 1">
          <RegistryValue Root="HKLM" Key="Software\Google\Chrome\NativeMessagingHosts\com.browser_organizer.host"
                         Type="string" Value="[INSTALLFOLDER]com.browser_organizer.host.json" KeyPath="yes" />
        </Component>
        <Component Id="RegEdge" Bitness="always64" Condition="EDGE = 1">
          <RegistryValue Root="HKLM" Key="Software\Microsoft\Edge\NativeMessagingHosts\com.browser_organizer.host"
                         Type="string" Value="[INSTALLFOLDER]com.browser_organizer.host.json" KeyPath="yes" />
        </Component>
        <Component Id="RegChromium" Bitness="always64" Condition="CHROMIUM = 1">
          <RegistryValue Root="HKLM" Key="Software\Chromium\NativeMessagingHosts\com.browser_organizer.host"
                         Type="string" Value="[INSTALLFOLDER]com.browser_organizer.host.json" KeyPath="yes" />
        </Component>

        <!-- Also write the 32-bit hive (WOW6432Node) so 32-bit Chrome/Edge/Chromium find it. -->
        <Component Id="RegChrome32" Bitness="always32" Condition="CHROME = 1">
          <RegistryValue Root="HKLM" Key="Software\Google\Chrome\NativeMessagingHosts\com.browser_organizer.host"
                         Type="string" Value="[INSTALLFOLDER]com.browser_organizer.host.json" KeyPath="yes" />
        </Component>
        <Component Id="RegEdge32" Bitness="always32" Condition="EDGE = 1">
          <RegistryValue Root="HKLM" Key="Software\Microsoft\Edge\NativeMessagingHosts\com.browser_organizer.host"
                         Type="string" Value="[INSTALLFOLDER]com.browser_organizer.host.json" KeyPath="yes" />
        </Component>
        <Component Id="RegChromium32" Bitness="always32" Condition="CHROMIUM = 1">
          <RegistryValue Root="HKLM" Key="Software\Chromium\NativeMessagingHosts\com.browser_organizer.host"
                         Type="string" Value="[INSTALLFOLDER]com.browser_organizer.host.json" KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <Feature Id="Main" Title="Browser Organizer Host" Level="1">
      <ComponentRef Id="HostExe" />
      <ComponentRef Id="HostManifest" />
      <ComponentRef Id="RegChrome" />
      <ComponentRef Id="RegEdge" />
      <ComponentRef Id="RegChromium" />
      <ComponentRef Id="RegChrome32" />
      <ComponentRef Id="RegEdge32" />
      <ComponentRef Id="RegChromium32" />
    </Feature>
  </Package>
</Wix>
